# ── Telegram ──────────────────────────────────────────────────────────────
# Bot token from BotFather.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram chat IDs allowed to run commands.
# IMPORTANT: blank = DENY ALL. This is a remote-command endpoint — only add
# your own chat ID(s).
TELEGRAM_ALLOWED_CHATS=

# ── SSH into the parent host ────────────────────────────────────────────────
# From inside the container the host is host.docker.internal (see docker-compose).
SSH_HOST=host.docker.internal
SSH_PORT=22
# Non-root host account the bot logs in as. It MUST NOT have sudo.
SSH_USER=botuser
# Path (inside the container) to the mounted private key.
SSH_KEY=/secrets/id_ed25519
# known_hosts file pinning the host key.
SSH_KNOWN_HOSTS=/secrets/known_hosts

# ── Execution limits ────────────────────────────────────────────────────────
# Per-command timeout in seconds; commands exceeding it are killed.
COMMAND_TIMEOUT_SECS=30

# ── Image publishing (make build-prod) ──────────────────────────────────────
DOCKER_USERNAME=
PROD_PLATFORM=linux/arm64
RUN_IMAGE=host-controller
