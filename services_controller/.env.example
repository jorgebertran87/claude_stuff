# Path to the YAML file declaring alias → service mappings.
ALIAS_CONFIG=/config/aliases.yaml

# Docker Engine HTTP API endpoint (a TCP proxy in front of the daemon socket).
DOCKER_API_URL=http://localhost:2375

# Telegram bot token from BotFather (required only for `services_controller bot`).
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs allowed to control services. Blank = allow any chat.
TELEGRAM_ALLOWED_CHATS=
