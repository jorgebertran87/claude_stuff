# Path to the YAML file declaring alias → service-directory mappings.
ALIAS_CONFIG=/config/aliases.yaml

# Host tree holding your per-service compose projects, mounted into the
# controller container at the same path your aliases reference.
SERVICES_ROOT=/srv

# Telegram bot token from BotFather (required only for `services_controller bot`).
TELEGRAM_BOT_TOKEN=

# Comma-separated chat IDs allowed to control services. Blank = allow any chat.
TELEGRAM_ALLOWED_CHATS=
