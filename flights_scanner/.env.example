# Sky Scrapper API key (RapidAPI) — sign up at rapidapi.com, subscribe to "Sky Scrapper"
# Takes priority over SKYSCANNER_API_KEY if both are set.
# SKY_SCRAPPER_API_KEY=your_key_here

# Skyscanner official API key — requires an approved commercial partnership.
# SKYSCANNER_API_KEY=your_key_here

# If neither key is set the server falls back to the in-memory provider.
