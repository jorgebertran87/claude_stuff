# ── Required ──────────────────────────────────────────────────────────────────

# Telegram Bot token — get one from @BotFather.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram chat ID (group, channel, or private chat).
# Forward a message to @userinfobot or @RawDataBot to find the ID.
TELEGRAM_CHAT_ID=-1001234567890

# ── Optional ──────────────────────────────────────────────────────────────────

# WebDriver server URL (used by browser-mode monitors).
# Default matches the "chrome" service name in docker-compose.yml.
# WEBDRIVER_URL=http://chrome:4444

# FlareSolverr API URL (used by flare-mode monitors — Cloudflare bypass).
# Default matches the "flaresolverr" service name in docker-compose.yml.
# FLARESOLVERR_URL=http://flaresolverr:8191

# Where to persist state files and the monitor list inside the container.
# Default: /data
# DATA_DIR=/data

# Log level: error | warn | info | debug | trace
RUST_LOG=changes_detector=info

# ── Deployment ────────────────────────────────────────────────────────────────

# Docker Hub username — used to tag and push the production image.
DOCKER_USERNAME=

# Chrome image — the default works on amd64; override only on ARM hosts:
#   CHROME_IMAGE=seleniarm/standalone-chromium:latest
# CHROME_IMAGE=selenium/standalone-chrome:latest

# Target platform for the production build (must match the prod host's arch).
PROD_PLATFORM=linux/amd64

# Platform used for local builds (matches your dev machine architecture).
LOCAL_PLATFORM=linux/amd64
