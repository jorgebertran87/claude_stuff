# ── Required ──────────────────────────────────────────────────────────────────

# Full path to the file to monitor (inside the container).
MONITOR_FILE=/watched/target.txt

# Telegram Bot token — get one from @BotFather.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram chat ID (group, channel, or private chat).
# Forward a message to @userinfobot or @RawDataBot to find the ID.
TELEGRAM_CHAT_ID=-1001234567890

# ── Optional ──────────────────────────────────────────────────────────────────

# How often to check for changes (seconds). Default: 60.
CHECK_INTERVAL_SECS=60

# Where to write the state snapshot inside the container.
# Defaults to /data/<filename>.state — usually no need to change.
# STATE_FILE=/data/custom.state

# Log level. Values: error | warn | info | debug | trace
RUST_LOG=changes_detector=info
