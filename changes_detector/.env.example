# ── Required ──────────────────────────────────────────────────────────────────

# What to monitor.
#   • http:// / https:// prefix  →  HTTP source  (static fetch, no JS)
#   • any other value            →  local file source
#   SOURCE_TYPE=browser overrides the auto-detection (see below).
MONITOR_TARGET=https://ticketing.rcdeportivo.es/

# Telegram Bot token — get one from @BotFather.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram chat ID (group, channel, or private chat).
# Forward a message to @userinfobot or @RawDataBot to find the ID.
TELEGRAM_CHAT_ID=-1001234567890

# ── Source type ───────────────────────────────────────────────────────────────

# Force a specific source implementation.
# Values: file | http | browser
# Default: auto-detected from MONITOR_TARGET (http→HttpSource, else FileSource)
#
# Use "browser" for JavaScript-heavy SPAs that render content client-side.
SOURCE_TYPE=browser

# ── HTTP / Browser source options ─────────────────────────────────────────────

# CSS selector to narrow monitoring to a specific element.
# Note: CSS IDs cannot start with a digit — use the attribute form:
#   a[id="237"]   ✔
#   #237          ✘
# CSS selector for the element to monitor.
#
# Use the universal attribute form for ids — CSS identifiers cannot start
# with a digit, so #237 and 360-match-banner-card[id="237"] are invalid.
#
# Descendant combinators work normally, e.g. to monitor a button inside a card:
#   [id="237"] .c-mb-card__main__actions__buy__btn
HTML_SELECTOR=[id="237"] .c-mb-card__main__actions__buy__btn

# WebDriver server URL (used by BrowserSource only).
# Default matches the "chrome" service name in docker-compose.yml.
WEBDRIVER_URL=http://chrome:4444

# ── Optional ──────────────────────────────────────────────────────────────────

# How often to check for changes (seconds). Default: 60.
CHECK_INTERVAL_SECS=60

# Where to persist the state snapshot inside the container.
# Defaults to /data/<slug>.state — usually no need to change.
# STATE_FILE=/data/custom.state

# Log level: error | warn | info | debug | trace
RUST_LOG=changes_detector=info
