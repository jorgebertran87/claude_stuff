# Telegram bot — create via @BotFather; the chat id is your own chat with the bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Mercadona search (Algolia). The app id is public; the search-only API key
# can be read from tienda.mercadona.es page source / network tab.
MERCADONA_APP_ID=7UZJKL1DJ0
MERCADONA_API_KEY=

# FlareSolverr instance used by the Dia source (docker-compose service).
FLARESOLVERR_URL=http://flaresolverr:8191

# Glovo (/glovo compares your order history). The token normally arrives
# automatically: route your phone through the glovo_capture mitmproxy and it
# writes the token to the shared file below. See capture/README.md.
#   - GLOVO_TOKEN seeds that file on first boot if it is still empty, and is
#     a manual fallback (you can also paste one any time with /glovo_token).
#   - GLOVO_TOKEN_FILE is the shared path; leave the default unless you remap
#     the volume. It must match the addon's path in docker-compose.
GLOVO_TOKEN=
GLOVO_TOKEN_FILE=/data/glovo_token

# Deployment (make build-prod / deploy).
DOCKER_USERNAME=
PROD_PLATFORM=linux/amd64
